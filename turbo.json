{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "MCP_LEGACY_ROOT",
        "MCP_COMMAND",
        "MCP_ARGS",
        "SQLITE_PATH",
        "LM_STUDIO_BASE_URL",
        "LM_STUDIO_MODEL"
      ]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "lint": {}
  }
}
