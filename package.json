{
  "name": "prd-assist",
  "private": true,
  "type": "module",
  "engines": {
    "pnpm": ">=9",
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "concurrently -n server,web -c cyan,magenta \"tsx watch src/server/index.ts\" \"vite\"",
    "build": "tsc -p tsconfig.json && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --no-error-on-unmatched-pattern 'src/**/*.{ts,tsx}' 'scripts/**/*.ts'",
    "test": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "better-sqlite3": "^11.10.0",
    "hono": "^4.12.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "zod": "^3.25.76"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  }
}
