{
  "name": "prd-assist",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "pnpm": ">=9",
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "turbo dev --filter=@prd-assist/server --filter=@prd-assist/web",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "lint": "eslint --no-error-on-unmatched-pattern 'apps/*/src/**/*.{ts,tsx}' 'packages/*/src/**/*.ts' 'scripts/**/*.ts'",
    "doc-edit-check": "tsx scripts/doc-edit-check.ts"
  },
  "dependencies": {
    "@prd-assist/shared": "workspace:*"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3"
  }
}
